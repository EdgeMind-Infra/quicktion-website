{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'CHANGED=$(git diff --name-only HEAD 2>/dev/null | grep -E \"^src/\" | head -1); if [ -n \"$CHANGED\" ]; then echo \"[dev-workflow] 检测到 src/ 下有代码变更，请运行 /simplify 检查代码质量\"; fi'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(pnpm format:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm lint\\:fix:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm astro:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs"
    ]
  }
}
