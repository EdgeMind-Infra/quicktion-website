---
// 功能特色 Tab 切换区块
const features = [
  {
    key: "chat",
    tab: "对话式触发",
    title: "随时随地对话",
    desc: "用自然语言与巨象对话——发布内容、联系达人、生成报告，说出来就能做到。",
  },
  {
    key: "multi",
    tab: "多店铺管理",
    title: "多店铺，统一指挥",
    desc: "统一下达任务，让扩张不再是负担。",
  },
  {
    key: "schedule",
    tab: "定时任务",
    title: "设好时间，自动运转",
    desc: "把重复性劳动变成定时任务，每周一发竞品简报、节假日自动上下架活动商品。",
  },
  {
    key: "im",
    tab: "微信飞书接入",
    title: "微信飞书，随时下令",
    desc: "不需要打开任何新 App，在微信和飞书里发出指令。",
  },
  {
    key: "browser",
    tab: "浏览器执行",
    title: "浏览器里，代你操作",
    desc: "内置浏览器自动化能力，像人一样打开网页、点击按钮、填写表单。",
  },
];
---

<section class="feature-tabs" id="features">
  <div class="sec-hdr">
    <h2 class="sec-title">我们的特色，强大易用</h2>
  </div>
  <div class="ft-tabs" role="tablist">
    {
      features.map((f, i) => (
        <button
          class:list={["ft-tab", i === 0 ? "active" : ""]}
          data-tab={f.key}
          type="button"
          role="tab"
        >
          {f.tab}
        </button>
      ))
    }
  </div>
  <div class="ft-content">
    {
      features.map((f, i) => (
        <div class:list={["ft-panel", i === 0 ? "active" : ""]} id={`ftab-${f.key}`}>
          <div class="ft-left">
            <h3 class="ft-feature-title">{f.title}</h3>
            <p class="ft-feature-desc">{f.desc}</p>
          </div>
          <div class="ft-right">
            <div class="ft-placeholder">功能演示占位</div>
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .feature-tabs {
    background: #fff;
    padding: 88px 60px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }
  .sec-hdr {
    text-align: center;
  }
  .sec-title {
    font-size: 40px;
    font-weight: 800;
    color: #1e293b;
  }
  .ft-tabs {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .ft-tab {
    padding: 10px 26px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 500;
    background: rgba(255, 255, 255, 0.7);
    color: #888;
    border: 1px solid transparent;
    cursor: pointer;
    backdrop-filter: blur(8px);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.25s, color 0.2s, background 0.2s;
  }
  .ft-tab:hover {
    color: #ff6b35;
    background: rgba(255, 107, 53, 0.05);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255, 107, 53, 0.12);
  }
  .ft-tab.active {
    background: linear-gradient(135deg, #ff5500 0%, #ff6b35 40%, #ff4d8a 100%);
    color: #fff;
    font-weight: 700;
    box-shadow: 0 4px 18px rgba(255, 107, 53, 0.4),
      0 1px 0 rgba(255, 255, 255, 0.2) inset;
    transform: translateY(-2px) scale(1.06);
  }
  .ft-content {
    width: 100%;
    max-width: 1300px;
  }
  .ft-panel {
    display: none;
    gap: 72px;
    align-items: center;
    background: #fff;
    border-radius: 24px;
    padding: 72px 80px;
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.06);
  }
  .ft-panel.active {
    display: flex;
    animation: panelIn 0.45s cubic-bezier(0.34, 1.4, 0.64, 1);
  }
  @keyframes panelIn {
    from { opacity: 0; transform: translateY(16px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  .ft-left {
    flex: 0 0 320px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .ft-feature-title {
    font-size: 28px;
    font-weight: 800;
    color: #1e293b;
    line-height: 1.3;
  }
  .ft-feature-desc {
    font-size: 16px;
    color: #666;
    line-height: 1.8;
  }
  .ft-right {
    flex: 1;
    min-height: 380px;
    border-radius: 16px;
    background: #fffbf7;
    border: 1px solid #ffe0cc;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ft-placeholder {
    color: #bbb;
    letter-spacing: 2px;
  }
  @media (max-width: 768px) {
    .feature-tabs {
      padding: 48px 20px;
    }
    .sec-title {
      font-size: 28px;
    }
    .ft-panel {
      flex-direction: column;
      padding: 32px 20px;
      gap: 24px;
    }
    .ft-left {
      flex: initial;
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>(".ft-tab");
  const panels = document.querySelectorAll<HTMLDivElement>(".ft-panel");

  function activate(idx: number) {
    tabs.forEach((t, i) => t.classList.toggle("active", i === idx));
    panels.forEach((p, i) => p.classList.toggle("active", i === idx));
  }

  tabs.forEach((btn, i) => {
    btn.addEventListener("click", () => {
      clearInterval(timer);
      activate(i);
      timer = setInterval(auto, 4000);
    });
  });

  let cur = 0;
  const auto = () => {
    cur = (cur + 1) % tabs.length;
    activate(cur);
  };
  let timer = setInterval(auto, 4000);
</script>
