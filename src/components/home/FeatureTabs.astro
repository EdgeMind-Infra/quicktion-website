---
import { type Lang, homeStrings } from "../../i18n/home";
import { withBase } from "../../lib/paths";

interface Props {
  lang?: Lang;
}
const { lang = "zh" } = Astro.props;
const t = homeStrings[lang].featureTabs;

const tabVideos: Record<string, string | null> = {
  chat: withBase("/videos/chat.mp4"),
  multi: null, // TODO(feature-tabs): 录制多店铺管理演示后补 public/videos/multi.mp4；当前先用静态图占位
  schedule: withBase("/videos/schedule.mp4"),
  im: withBase("/videos/im.mp4"),
  browser: withBase("/videos/browser.mp4"),
};

// 尚无视频时可用静态图占位。video 优先级高于 image，两者都缺才回落到文字 placeholder。
const tabImages: Record<string, string | null> = {
  multi: withBase("/images/multistore.png"),
};
---

<section class="feature-tabs" id="features">
  <div class="sec-hdr">
    <h2 class="sec-title">{t.sectionTitle}</h2>
  </div>
  <div class="ft-tabs" role="tablist">
    {
      t.features.map((f, i) => (
        <button
          class:list={["ft-tab", i === 0 ? "active" : ""]}
          data-tab={f.key}
          type="button"
          role="tab"
        >
          {f.tab}
        </button>
      ))
    }
  </div>
  <div class="ft-content">
    {
      t.features.map((f, i) => {
        const video = tabVideos[f.key];
        const image = !video ? tabImages[f.key] : null;
        return (
          <div class:list={["ft-panel", i === 0 ? "active" : ""]} id={`ftab-${f.key}`}>
            <div class="ft-left">
              <h3 class="ft-feature-title">{f.title}</h3>
              <p class="ft-feature-desc">{f.desc}</p>
            </div>
            <div class:list={["ft-right", video && "has-video", image && "has-image"]}>
              {video ? (
                /* preload="none" 避免 4 个视频同时抢带宽；activate() 会切到 metadata 并 play 激活 tab */
                <video muted loop playsinline preload="none" class="ft-video">
                  <source src={video} type="video/mp4" />
                </video>
              ) : image ? (
                <img src={image} alt={f.title} class="ft-image" loading="lazy" />
              ) : (
                <div class="ft-placeholder">{f.placeholder}</div>
              )}
            </div>
          </div>
        );
      })
    }
  </div>
</section>

<style>
  .feature-tabs {
    background: #fff;
    padding: 88px 60px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }
  .ft-tabs {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .ft-tab {
    padding: 12px 24px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 500;
    background: #fff;
    color: var(--landing-text-muted);
    border: 0.8px solid var(--landing-border);
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .ft-tab:hover {
    color: var(--landing-brand-dark);
    background: var(--landing-hover);
    border-color: var(--landing-brand-light);
  }
  .ft-tab.active {
    background: var(--landing-brand-dark);
    color: #fff;
    font-weight: 500;
    border-color: transparent;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.15),
      0 10px 28px -8px rgb(var(--landing-brand-rgb) / 0.55);
  }
  /* Grid stack：所有 panel 堆叠在同一个 cell，容器高度取最高者，
     切换时纯 opacity 过渡，不触发 layout 闪烁。 */
  .ft-content {
    width: 100%;
    max-width: var(--landing-container, 1200px);
    display: grid;
    grid-template-columns: 1fr;
  }
  .ft-panel {
    grid-row: 1;
    grid-column: 1;
    display: flex;
    gap: 72px;
    align-items: center;
    background: #fff;
    border-radius: 24px;
    padding: 72px 80px;
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.06);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .ft-panel.active {
    opacity: 1;
    pointer-events: auto;
  }
  .ft-left {
    flex: 0 0 320px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .ft-feature-title {
    font-size: 28px;
    font-weight: 800;
    color: #1e293b;
    line-height: 1.3;
  }
  .ft-feature-desc {
    font-size: 16px;
    color: #666;
    line-height: 1.8;
  }
  .ft-right {
    flex: 1;
    aspect-ratio: 16 / 9;
    border-radius: 16px;
    background: #fffbf7;
    border: 1px solid #ffe0cc;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  /* 视频槽位：干净无边框，让视频完全贴合圆角；占位态仍保留主题色边框 */
  .ft-right.has-video {
    padding: 0;
    background: #000;
    border: none;
  }
  /* 图片槽位：保留淡橙主题底色作为 contain 时的留边，和外框呼应 */
  .ft-right.has-image {
    padding: 0;
  }
  .ft-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ft-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .ft-placeholder {
    color: #bbb;
    letter-spacing: 2px;
  }
  @media (max-width: 768px) {
    .feature-tabs {
      /* section 去掉左右 padding，让 ft-tabs 横向滚动贴边；内部区域各自管 padding */
      padding: 48px 0;
      gap: 32px;
    }
    .sec-hdr,
    .ft-content {
      padding: 0 16px;
    }
    /* 横向滚动 tabs：nowrap + overflow-x + 隐藏滚动条 + 右侧渐隐提示溢出 */
    .ft-tabs {
      flex-wrap: nowrap;
      justify-content: flex-start;
      overflow-x: auto;
      overflow-y: hidden;
      gap: 8px;
      padding: 0 16px 4px;
      scroll-snap-type: x proximity;
      scrollbar-width: none;
      -ms-overflow-style: none;
      -webkit-mask-image: linear-gradient(to right, #000 0, #000 calc(100% - 24px), transparent 100%);
      mask-image: linear-gradient(to right, #000 0, #000 calc(100% - 24px), transparent 100%);
    }
    .ft-tabs::-webkit-scrollbar {
      display: none;
    }
    .ft-tab {
      flex: 0 0 auto;
      scroll-snap-align: start;
      padding: 10px 18px;
      font-size: 13px;
    }

    .ft-panel {
      flex-direction: column;
      padding: 24px 16px;
      gap: 20px;
      border-radius: 16px;
    }
    .ft-left {
      flex: initial;
      width: 100%;
    }
    .ft-feature-title {
      font-size: 22px;
    }
    .ft-feature-desc {
      font-size: 15px;
      line-height: 1.7;
    }
    /* mobile：desktop 的 aspect-ratio 已是 16:9，这里仅收圆角 + 修正 flex 到 full width */
    .ft-right {
      width: 100%;
      flex: initial;
      border-radius: 12px;
    }
  }
</style>

<script>
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>(".ft-tab"));
  const panels = Array.from(document.querySelectorAll<HTMLDivElement>(".ft-panel"));
  const videos = panels.map((p) => p.querySelector<HTMLVideoElement>(".ft-video"));
  const tabsContainer = document.querySelector<HTMLElement>(".ft-tabs");
  const AUTO_MS = 10000;

  function scrollActiveTabIntoCenter(idx: number) {
    const tab = tabs[idx];
    if (!tabsContainer || !tab) return;
    // Desktop 下 tabs 不溢出，无需调整；避免 scrollIntoView 的全页级联滚动
    if (tabsContainer.scrollWidth <= tabsContainer.clientWidth) return;
    const target = tab.offsetLeft - (tabsContainer.clientWidth - tab.offsetWidth) / 2;
    tabsContainer.scrollTo({ left: Math.max(0, target), behavior: "smooth" });
  }

  function activate(idx: number) {
    cur = idx;
    tabs.forEach((t, i) => t.classList.toggle("active", i === idx));
    panels.forEach((p, i) => p.classList.toggle("active", i === idx));
    // 仅激活 tab 的视频播放；其他全部 pause + 卸载 preload，避免 4 个视频并行解码
    videos.forEach((v, i) => {
      if (!v) return;
      if (i === idx) {
        v.preload = "auto";
        void v.play().catch(() => {});
      } else {
        v.pause();
      }
    });
    scrollActiveTabIntoCenter(idx);
  }

  let cur = 0;
  let timer = window.setInterval(() => activate((cur + 1) % tabs.length), AUTO_MS);

  tabs.forEach((btn, i) => {
    btn.addEventListener("click", () => {
      window.clearInterval(timer);
      activate(i);
      timer = window.setInterval(() => activate((cur + 1) % tabs.length), AUTO_MS);
    });
  });

  // 初始化：让 active tab 的视频立刻开始播
  activate(0);
</script>
