---
// 落地 CTA 区块
import { type Lang, homeStrings } from "../../i18n/home";

interface Props {
  lang?: Lang;
}
const { lang = "zh" } = Astro.props;
const t = homeStrings[lang].cta;
---

<section class="cta-section">
  <h2 class="cta-title">{t.title}</h2>
  <p class="cta-sub">{t.sub}</p>
  <div class="cta-btns">
    <button class="cta-btn-primary" type="button">{t.button}</button>
  </div>
</section>

<style>
  .cta-section {
    background: #fff;
    padding: 120px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }
  .cta-title {
    font-size: 52px;
    font-weight: 800;
    color: #1a1a1a;
    line-height: 1.2;
  }
  .cta-sub {
    font-size: 17px;
    color: #888;
    font-weight: 300;
  }
  .cta-btns {
    margin-top: 16px;
  }
  .cta-btn-primary {
    padding: 14px 48px;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    background: #ff6b35;
    color: #fff;
    font-size: 17px;
    font-weight: 700;
    box-shadow: 0 6px 20px rgba(255, 107, 53, 0.35);
    transition: background 0.2s, transform 0.2s;
  }
  .cta-btn-primary:hover {
    background: #ff5500;
    transform: translateY(-1px);
  }
  @media (max-width: 768px) {
    .cta-section {
      padding: 64px 16px;
      gap: 12px;
    }
    .cta-title {
      font-size: 30px;
      line-height: 1.25;
    }
    .cta-sub {
      font-size: 15px;
      line-height: 1.6;
      max-width: 420px;
    }
    .cta-btns {
      width: 100%;
      margin-top: 20px;
    }
    .cta-btn-primary {
      width: 100%;
      padding: 14px 24px;
      font-size: 16px;
    }
  }
</style>
