---
// 首页 Hero：单列居中 H1 + pill 标签 + 双 CTA + 下方 16:9 视频卡
import { type Lang, homeStrings } from "../../i18n/home";

interface Props {
  lang?: Lang;
}
const { lang = "zh" } = Astro.props;
const t = homeStrings[lang].hero;

// 临时热链 Accio 的产品 demo 视频作为占位——上线前必须替换为 Quicktion 自己的录屏
const HERO_VIDEO_SRC = "https://work-download.accio.com/videos/home.mp4";
const HERO_VIDEO_POSTER =
  "https://s.alicdn.com/@img/imgextra/i3/O1CN01Sh4XDv1gFLkgsu2lg_!!6000000004112-2-tps-3016-1890.png";
---

<section class="hero">
  <div class="hero-inner">
    <h1 class="hero-title">
      {t.title}
    </h1>

    <div class="hero-pills">
      <span class="hero-pill"><span class="pill-glyph">✦</span>{t.pill1}</span>
      <span class="hero-pill"><span class="pill-glyph">✦</span>{t.pill2}</span>
      <span class="hero-pill"><span class="pill-glyph">✦</span>{t.pill3}</span>
    </div>

    <p class="hero-desc">
      {t.desc}
    </p>

    <div class="hero-ctas">
      <button class="btn-primary" type="button">
        <span>{t.ctaPrimary}</span>
      </button>
      <button class="btn-secondary" type="button" id="btnDemo">
        <span>{t.ctaSecondary}</span>
      </button>
    </div>

    <div class="hero-video" id="heroVideo">
      <div class="video-chrome" aria-hidden="true">
        <span class="dot dot-r"></span>
        <span class="dot dot-y"></span>
        <span class="dot dot-g"></span>
      </div>
      <video
        class="video-media"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster={HERO_VIDEO_POSTER}
      >
        <source src={HERO_VIDEO_SRC} type="video/mp4" />
      </video>
    </div>
  </div>
</section>

<style>
  .hero {
    background: radial-gradient(
      ellipse closest-side at 50% 38%,
      var(--landing-brand-light) 0%,
      #fff5ee 40%,
      #fff 80%
    );
    padding: 72px 24px 96px;
  }
  .hero-inner {
    max-width: var(--landing-container, 1200px);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .hero-title {
    font-family: "Noto Sans SC", "PingFang SC", sans-serif;
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--landing-text-main);
    text-align: center;
    margin-top: 12px;
  }

  .hero-pills {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--landing-brand-light);
    border-radius: 999px;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 600;
    color: var(--landing-brand-dark);
  }
  .pill-glyph {
    color: var(--landing-brand);
    font-size: 11px;
  }

  .hero-desc {
    font-size: 17px;
    color: var(--landing-text-muted);
    text-align: center;
    line-height: 1.7;
    max-width: 640px;
  }

  .hero-ctas {
    display: flex;
    gap: 16px;
    align-items: center;
    margin-top: 12px;
  }
  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 32px;
    border-radius: 999px;
    font-size: 16px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition:
      transform 0.15s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.15s cubic-bezier(0.4, 0, 0.2, 1),
      filter 0.15s cubic-bezier(0.4, 0, 0.2, 1);
    font-family: inherit;
  }
  .btn-primary {
    background: var(--landing-brand-dark);
    color: #fff;
    box-shadow:
      0 10px 15px -3px rgb(var(--landing-brand-rgb) / 0.3),
      0 4px 6px -4px rgb(var(--landing-brand-rgb) / 0.25);
  }
  .btn-secondary {
    background: var(--landing-brand);
    color: #fff;
    box-shadow:
      0 10px 15px -3px rgb(var(--landing-brand-rgb) / 0.25),
      0 4px 6px -4px rgb(var(--landing-brand-rgb) / 0.2);
  }
  .btn-primary:hover,
  .btn-secondary:hover {
    transform: translateY(-1px);
    filter: brightness(1.04);
    box-shadow:
      0 14px 24px -4px rgb(var(--landing-brand-rgb) / 0.4),
      0 6px 10px -4px rgb(var(--landing-brand-rgb) / 0.3);
  }

  .hero-video {
    position: relative;
    width: 100%;
    max-width: 1120px;
    aspect-ratio: 16 / 9;
    margin-top: 40px;
    border-radius: 24px;
    overflow: hidden;
    background: #0f172a;
    border: 0.8px solid var(--landing-border);
    box-shadow: 0 30px 60px -20px rgba(15, 23, 42, 0.25);
  }
  .video-chrome {
    position: absolute;
    top: 14px;
    left: 16px;
    display: flex;
    gap: 6px;
    z-index: 2;
  }
  .video-chrome .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dot-r { background: #ff5f57; }
  .dot-y { background: #febc2e; }
  .dot-g { background: #28c840; }
  .video-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 48px 16px 64px;
    }
    .hero-title {
      font-size: clamp(28px, 8vw, 38px);
    }
    .hero-desc {
      font-size: 16px;
      line-height: 1.65;
    }
    .hero-ctas {
      flex-direction: column;
      width: 100%;
      max-width: none;
      gap: 12px;
      /* .hero-inner 是 align-items: center 的 column flex，
         子元素默认 shrink-to-content；必须 align-self: stretch 才能真的全宽 */
      align-self: stretch;
    }
    .btn-primary,
    .btn-secondary {
      width: 100%;
      padding: 14px 24px;
      font-size: 15px;
    }
    .hero-video {
      margin-top: 24px;
      border-radius: 16px;
    }
  }
</style>

<script>
  const btnDemo = document.getElementById("btnDemo");
  const heroVideo = document.getElementById("heroVideo");
  btnDemo?.addEventListener("click", () => {
    heroVideo?.scrollIntoView({ behavior: "smooth", block: "center" });
  });
</script>
