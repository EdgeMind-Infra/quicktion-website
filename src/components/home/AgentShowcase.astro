---
// Agent 三兄弟展示：分析 / 策划 / 执行
const agents = [
  {
    badge: "分析 Agent",
    title: "专属「数据医生」",
    desc: "接入平台一手数据，诊断经营盲区，给出可落地的增长建议。",
    tags: ["店铺诊断报告", "竞品动态监控", "爆款内容解码"],
    reverse: false,
  },
  {
    badge: "策划 Agent",
    title: "你的「点子智囊团」",
    desc: "基于数据生成营销方案，说出需求，即可获得可落地的完整策略。",
    tags: ["达人营销方案", "本地推投流策略", "商品活动策划"],
    reverse: true,
  },
  {
    badge: "执行 Agent",
    title: "数字员工上岗",
    desc: "方案确定后自动执行，重复琐碎的工作全部交给数字员工。",
    tags: ["抖音达人合作", "线上内容运营", "经营指标提升"],
    reverse: false,
  },
];
---

<section class="product-section" id="product">
  <div class="sec-hdr">
    <h2 class="sec-title">从诊断到优化，营销全流程闭环</h2>
    <p class="sec-sub">AI 数字员工分工协作，让每个环节都有专属智能助理</p>
  </div>
  {
    agents.map((a) => (
      <div class:list={["agent-row", a.reverse ? "reverse" : ""]}>
        <div class="agent-text">
          <span class="agent-badge">{a.badge}</span>
          <h3 class="agent-title">{a.title}</h3>
          <p class="agent-desc">{a.desc}</p>
          <div class="agent-tags">
            {a.tags.map((t) => <span class="agent-tag">{t}</span>)}
          </div>
        </div>
        <div class="agent-ui">
          <div class="agent-ui-placeholder">界面演示占位</div>
        </div>
      </div>
    ))
  }
</section>

<style>
  .product-section {
    padding: 80px 60px;
    display: flex;
    flex-direction: column;
    gap: 96px;
    align-items: center;
    background:
      radial-gradient(ellipse 700px 500px at 15% 20%, rgba(255, 140, 80, 0.07) 0%, transparent 70%),
      radial-gradient(ellipse 600px 600px at 85% 10%, rgba(255, 100, 130, 0.06) 0%, transparent 65%),
      radial-gradient(ellipse 800px 500px at 60% 60%, rgba(255, 160, 60, 0.05) 0%, transparent 65%),
      #fff;
  }
  .sec-hdr {
    text-align: center;
  }
  .sec-title {
    font-size: 40px;
    font-weight: 800;
    color: #1e293b;
  }
  .sec-sub {
    font-size: 17px;
    color: #888;
    margin-top: 12px;
  }
  .agent-row {
    display: flex;
    align-items: center;
    gap: 56px;
    width: 100%;
    max-width: 1300px;
  }
  .agent-row.reverse {
    flex-direction: row-reverse;
  }
  .agent-text {
    flex: 0 0 360px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .agent-badge {
    align-self: flex-start;
    font-family: "Inter", sans-serif;
    font-size: 14px;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 999px;
    background: rgba(255, 107, 53, 0.1);
    color: #ff5500;
    letter-spacing: 0.5px;
  }
  .agent-title {
    font-size: 28px;
    font-weight: 800;
    color: #1a1a1a;
    line-height: 1.3;
  }
  .agent-desc {
    font-size: 15px;
    color: #888;
    line-height: 1.75;
    font-weight: 300;
  }
  .agent-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .agent-tag {
    padding: 6px 16px;
    border-radius: 999px;
    font-size: 13px;
    color: #333;
    border: 1.5px solid #e0e0e0;
    background: #fff;
    transition: border-color 0.25s, color 0.25s, transform 0.25s,
      box-shadow 0.25s;
  }
  .agent-tag:hover {
    border-color: transparent;
    color: #ff5500;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
    transform: translateY(-1.5px);
  }
  .agent-ui {
    flex: 1;
    min-width: 0;
    height: 420px;
    border-radius: 20px;
    background: #fffbf7;
    border: 1px solid #ffe0cc;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.07);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .agent-ui-placeholder {
    color: #bbb;
    letter-spacing: 2px;
  }
  @media (max-width: 768px) {
    .product-section {
      padding: 48px 20px;
      gap: 60px;
    }
    .sec-title {
      font-size: 28px;
    }
    .agent-row,
    .agent-row.reverse {
      flex-direction: column;
      gap: 24px;
    }
    .agent-text {
      flex: initial;
    }
    .agent-ui {
      width: 100%;
      height: 280px;
    }
  }
</style>
