---
// Agent 三兄弟展示：分析 / 策划 / 执行
import { type Lang, homeStrings } from "../../i18n/home";

interface Props {
  lang?: Lang;
}
const { lang = "zh" } = Astro.props;
const t = homeStrings[lang].agents;
---

<section class="product-section" id="product">
  <div class="sec-hdr">
    <h2 class="sec-title">{t.sectionTitle}</h2>
    <p class="sec-sub">{t.sectionSub}</p>
  </div>
  {
    t.items.map((a, i) => (
      <div class:list={["agent-row", i % 2 === 1 ? "reverse" : ""]}>
        <div class="agent-text">
          <span class="agent-badge">{a.badge}</span>
          <h3 class="agent-title">{a.title}</h3>
          <p class="agent-desc">{a.desc}</p>
          <div class="agent-tags">
            {a.tags.map((tag) => <span class="agent-tag">{tag}</span>)}
          </div>
        </div>
        <div class="agent-ui">
          <div class="agent-ui-placeholder">{t.uiPlaceholder}</div>
        </div>
      </div>
    ))
  }
</section>

<style>
  .product-section {
    padding: 80px 60px;
    display: flex;
    flex-direction: column;
    gap: 96px;
    align-items: center;
    background:
      radial-gradient(ellipse 700px 500px at 15% 20%, rgba(255, 140, 80, 0.07) 0%, transparent 70%),
      radial-gradient(ellipse 600px 600px at 85% 10%, rgba(255, 100, 130, 0.06) 0%, transparent 65%),
      radial-gradient(ellipse 800px 500px at 60% 60%, rgba(255, 160, 60, 0.05) 0%, transparent 65%),
      #fff;
  }
  .sec-hdr {
    text-align: center;
  }
  .sec-title {
    font-size: 40px;
    font-weight: 800;
    color: #1e293b;
  }
  .sec-sub {
    font-size: 17px;
    color: #888;
    margin-top: 12px;
  }
  .agent-row {
    display: flex;
    align-items: center;
    gap: 56px;
    width: 100%;
    max-width: var(--landing-container, 1200px);
  }
  .agent-row.reverse {
    flex-direction: row-reverse;
  }
  .agent-text {
    flex: 0 0 360px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .agent-badge {
    align-self: flex-start;
    font-family: "Inter", sans-serif;
    font-size: 14px;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 999px;
    background: rgba(255, 107, 53, 0.1);
    color: #ff5500;
    letter-spacing: 0.5px;
  }
  .agent-title {
    font-size: 28px;
    font-weight: 800;
    color: #1a1a1a;
    line-height: 1.3;
  }
  .agent-desc {
    font-size: 15px;
    color: #888;
    line-height: 1.75;
    font-weight: 300;
  }
  .agent-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .agent-tag {
    padding: 6px 16px;
    border-radius: 999px;
    font-size: 13px;
    color: #333;
    border: 1.5px solid #e0e0e0;
    background: #fff;
    transition: border-color 0.25s, color 0.25s, transform 0.25s,
      box-shadow 0.25s;
  }
  .agent-tag:hover {
    border-color: transparent;
    color: #ff5500;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
    transform: translateY(-1.5px);
  }
  .agent-ui {
    flex: 1;
    min-width: 0;
    height: 420px;
    border-radius: 20px;
    background: #fffbf7;
    border: 1px solid #ffe0cc;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.07);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .agent-ui-placeholder {
    color: #bbb;
    letter-spacing: 2px;
  }
  @media (max-width: 768px) {
    .product-section {
      padding: 48px 20px;
      gap: 60px;
    }
    .sec-title {
      font-size: 28px;
    }
    .agent-row,
    .agent-row.reverse {
      flex-direction: column;
      gap: 24px;
    }
    .agent-text {
      flex: initial;
    }
    .agent-ui {
      /* 父 .agent-row 在 mobile 下 flex-direction: column；继承的 `flex: 1` 里 flex-basis: 0%
         会在主轴（垂直）上覆盖 height，导致 .agent-ui 塌到 ~24px 占位高。必须 flex: initial。 */
      flex: initial;
      width: 100%;
      height: 280px;
    }
  }
</style>
