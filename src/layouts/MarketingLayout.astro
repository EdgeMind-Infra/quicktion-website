---
/**
 * Marketing 页面专用布局：独立于 Starlight 的站点壳。
 * 用于首页、定价页等品牌营销页面，完全掌控 HTML / head / nav / footer。
 *
 * lang prop 决定：
 * - html[lang] 属性（SEO / 辅助技术）
 * - 传给 SiteNav 的语言
 * - Footer 文案
 * - 默认 meta title/description（可被外部 props 覆盖）
 */
import "../styles/global.css";
import SiteNav from "../components/nav/SiteNav.astro";
import { type Lang, homeStrings } from "../i18n/home";
import { withBase } from "../lib/paths";

interface Props {
  title?: string;
  description?: string;
  lang?: "zh-CN" | "en";
}

const { title, description, lang = "zh-CN" } = Astro.props;
const navLang: Lang = lang === "en" ? "en" : "zh";
const s = homeStrings[navLang];

const pageTitle = title ?? s.meta.title;
const pageDesc = description ?? s.meta.description;
const brandName = navLang === "zh" ? "巨象" : "Quicktion";
const faviconHref = withBase("/favicon.svg");
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Noto+Sans+SC:wght@400;500;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <SiteNav variant="marketing" lang={navLang} />

    <main>
      <slot />
    </main>

    <footer class="marketing-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <img src={faviconHref} alt="" class="brand-mark sm" aria-hidden="true" />
          <span>{brandName} · quicktion.ai</span>
        </div>
        <p class="footer-copy">{s.footer.copy}</p>
      </div>
    </footer>

    <style is:global>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        font-family: "Inter", "Noto Sans SC", "PingFang SC", system-ui, sans-serif;
        color: #1a1a1a;
        background: #fff;
        scroll-behavior: smooth;
      }
      body {
        overflow-x: hidden;
      }
      a {
        text-decoration: none;
        color: inherit;
      }
      button {
        font-family: inherit;
      }
    </style>

    <style>
      .marketing-footer {
        background: #fff;
        padding: 24px 40px;
        border-top: 1px solid #f0f0f0;
      }
      .footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: var(--landing-container, 1200px);
        margin: 0 auto;
      }
      .footer-brand {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 15px;
        font-weight: 700;
      }
      .brand-mark.sm {
        width: 26px;
        height: 26px;
        display: inline-block;
        flex-shrink: 0;
      }
      .footer-copy {
        font-size: 13px;
        color: #aaa;
      }
    </style>
  </body>
</html>
